<Window
    x:Class="Shops_GUI_ISS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#F9FAFB" Padding="100 0 0 0" RequestedTheme="Light">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="30" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="DutyFree Shops"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#2bb8c0"
                       VerticalAlignment="Center" />

            <AutoSuggestBox Grid.Column="1"
                            Height="40"
                            PlaceholderText="Search shops or categories..."
                            CornerRadius="8" 
                            Width="500"
                            BorderBrush="LightGray"/>

            <Button Grid.Column="2"
                    CornerRadius="4"
                    Padding="15,8"
                    BorderThickness="0">
                <SymbolIcon Symbol="Contact" Foreground="Gray"/>
            </Button>

            <Button Grid.Column="3"
                    Background="#2bb8c0"
                    Foreground="White"
                    CornerRadius="4"
                    Padding="15,8">
                <SymbolIcon Symbol="Shop"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,40,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Padding="30,0,0,0" VerticalAlignment="Center">
                <Button Height="35" Width="110" Background="#2bb8c0" Foreground="White" 
                        Padding="5" Content="+ Add Shop" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Sort by:" VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox Width="220" SelectedIndex="0" Padding="5,2">
                    <ComboBoxItem Content="Shop Name" />
                    <ComboBoxItem Content="Reviews" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2">
            <GridView Padding="20">

                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="4" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="300"
                                Height="120"
                                Margin="10"
                                CornerRadius="12"
                                Background="White"
                                Padding="15">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>

                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Content}" 
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="Black" 
                                               Grid.Column="0"
                                               VerticalAlignment="Center" />

                                    <Button Width="40" Height="30" Foreground="Black" Grid.Column="1">
                                        <TextBlock Text="✎" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Width="40" Height="30" Foreground="Black" Grid.Column="2" Margin="15 0 0 0">
                                        <TextBlock Text="-" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <TextBlock Text="{Binding Tag}"
                                           Margin="0,5,0,0"
                                           FontSize="13"
                                           Opacity="0.6"
                                           Foreground="#2bb8c0" 
                                           FontWeight="Medium"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>

                <ContentControl Content="Chocolate Heaven" Tag="Confectionery &amp; Sweets" />
                <ContentControl Content="Cosmetics Corner" Tag="Beauty &amp; Fragrance" />
                <ContentControl Content="Designer Bags" Tag="Luxury Fashion" />
                <ContentControl Content="Gourmet Delights" Tag="Food &amp; Spirits" />
                <ContentControl Content="Luxury Boutique" Tag="High-End Accessories" />
                <ContentControl Content="Tech World" Tag="Electronics" />
                <ContentControl Content="Watch Station" Tag="Jewelry" />

            </GridView>
        </ScrollViewer>

    </Grid>
</Window>

