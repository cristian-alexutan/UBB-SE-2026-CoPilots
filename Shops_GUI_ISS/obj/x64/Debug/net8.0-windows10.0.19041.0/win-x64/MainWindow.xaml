<Window
    x:Class="Shops_GUI_ISS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Shops_GUI_ISS">

    <Grid Background="#F9FAFB" Padding="100 0 0 0" RequestedTheme="Light">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Grid Padding="30" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="DutyFree Shops"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="#2bb8c0"
                       VerticalAlignment="Center" />

            <AutoSuggestBox Grid.Column="1"
                            Height="40"
                            PlaceholderText="Search shops or categories..."
                            CornerRadius="8" 
                            Width="500"
                            BorderBrush="LightGray"/>

            <Button Grid.Column="2"
                    CornerRadius="4"
                    Padding="15,8"
                    BorderThickness="0">
                <SymbolIcon Symbol="Contact" Foreground="Gray"/>
            </Button>

            <Button Grid.Column="3"
                    Background="#2bb8c0"
                    Foreground="White"
                    CornerRadius="4"
                    Padding="15,8">
                <SymbolIcon Symbol="Shop"/>
            </Button>
        </Grid>

        <!-- Controls -->
        <Grid Grid.Row="1" Margin="0,0,40,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Padding="30,0,0,0" VerticalAlignment="Center">
                <!-- Add Shop button with name for code-behind -->
                <Button x:ConnectionId='9' x:Name="AddShopButton"
                        Height="35" Width="110"
                        Background="#2bb8c0" Foreground="White" 
                        Padding="5"
                        Content="+ Add Shop" />
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Sort by:" VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox Width="220" SelectedIndex="0" Padding="5,2">
                    <ComboBoxItem Content="Shop Name" />
                    <ComboBoxItem Content="Reviews" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Shops GridView -->
        <ScrollViewer Grid.Row="2">
            <GridView x:ConnectionId='2' x:Name="ShopsGridView" Padding="20">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="4" />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                <GridView.ItemTemplate>
                    <DataTemplate                            >
                        <Border x:ConnectionId='4' Width="300"
                                Height="120"
                                Margin="10"
                                CornerRadius="12"
                                Background="WhiteSmoke"
                                Padding="15">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:ConnectionId='6'                      
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="Black" 
                                               Grid.Column="0"
                                               VerticalAlignment="Center" />

                                    <Button x:ConnectionId='7' Width="40" Height="30" Grid.Column="1"                             
                                            DataContext="{Binding}"
                                                                                              >
                                        <TextBlock Text="✎" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>

                                    <Button x:ConnectionId='8' Width="40" Height="30" Grid.Column="2"                               
                                            DataContext="{Binding}"
                                                                                              >
                                        <TextBlock Text="-" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Button>
                                </Grid>

                                <TextBlock x:ConnectionId='5'                         
                                           Margin="0,5,0,0"
                                           Opacity="0.6"
                                           Foreground="Black" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>
        </ScrollViewer>

    </Grid>
</Window>

