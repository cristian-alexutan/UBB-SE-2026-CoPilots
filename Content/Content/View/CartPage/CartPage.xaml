<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Content.CartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Content"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CartView">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid Padding="20" RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">

            <Grid Padding="10,15,20,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderBrush="Transparent" Padding="10" Click="BackButton_Click">
                        <FontIcon Glyph="&#xE72B;" FontSize="16"/>
                    </Button>
                    <TextBlock Text="Duty-free shops" FontSize="22" FontWeight="SemiBold" Foreground="#2bb8c0" VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>

                <TextBox Grid.Column="1" PlaceholderText="Search..." Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderBrush="Transparent" Padding="10" Click="ProfileButton_Click">
                        <FontIcon Glyph="&#xE77B;" FontSize="18"/>
                    </Button>
                    <FontIcon Glyph="&#xE7BF;" FontSize="18" Foreground="Gray" Margin="20,0,10,0"/>
                </StackPanel>
            </Grid>

            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" />

            <Grid Padding="20,10,20,10">
                <ComboBox PlaceholderText="Alphabetic" IsHitTestVisible="False" Width="150" HorizontalAlignment="Left" Background="Transparent" BorderBrush="#EEEEEE"/>
            </Grid>

            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" />

        </StackPanel>
        <ListView Grid.Row="1" 
              ItemsSource="{x:Bind ViewModel.CartShopItems, Mode=OneWay}" 
              SelectionMode="None"
              MaxWidth="1300">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,15,0,15" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Source="/Assets/PlaceHolder.png" Width="80" Height="80" Margin="0,0,20,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ShopItem.Name}" FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding DisplayPrice}" FontSize="14" Foreground="Gray"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,40,0">
                            <Button Content="-" Width="40" Height="40" Margin="0,0,10,0" Click="DecreaseQuantity_Click"/>

                            <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" FontSize="18" Margin="0,0,10,0"/>

                            <Button Content="+" Width="40" Height="40" Click="IncreaseQuantity_Click"/>
                        </StackPanel>

                        <TextBlock Grid.Column="3" Text="{Binding ItemTotalPrice}" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="#2bb8c0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="2" Margin="0,30,0,0" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Empty Cart" HorizontalAlignment="Left" Background="Transparent" BorderBrush="#2bb8c0" BorderThickness="1" Foreground="#2bb8c0" Click="EmptyCart_Click"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">

                <StackPanel Orientation="Vertical" Margin="0,0,25,0" HorizontalAlignment="Right">
                    <TextBlock Text="Overall Total Price" FontSize="12" Foreground="Gray" HorizontalAlignment="Right"/>
                    <TextBlock Text="{x:Bind ViewModel.OverallTotal, Mode=OneWay}" FontSize="28" FontWeight="Bold" Foreground="#2bb8c0" HorizontalAlignment="Right"/>
                </StackPanel>

                <Button Content="Reserve" Width="140" Height="50" Background="#2bb8c0" Foreground="White" FontSize="16" FontWeight="SemiBold" 
            IsEnabled="{x:Bind ViewModel.IsReserveButtonEnabled, Mode=OneWay}"
            Click="Reserve_Click"/>

                <Button Content="Cancel Reservation" Width="170" Height="50" Background="LightPink" Foreground="DarkRed" FontSize="16" FontWeight="SemiBold" 
            Visibility="{x:Bind BoolToVisibility(ViewModel.IsCancelButtonVisible), Mode=OneWay}"
            Margin="15,0,0,0"
            Click="CancelReservation_Click"/>

            </StackPanel>
        </Grid>

    </Grid>

</Window>
