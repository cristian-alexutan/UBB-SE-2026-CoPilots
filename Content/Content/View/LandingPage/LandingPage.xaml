<?xml version="1.0" encoding="utf-8"?>
    
<Window
    x:Class="Content.LandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Content"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LandingPage">


    <Grid Background="White">
        <Grid.Resources>
            <Style x:Key="ButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="200"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="Background" Value="#2bb8c0"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="CornerRadius" Value="15"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Content="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <StackPanel Background="Transparent" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center" >
            <!--logo here-->
            <Image Source="/Assets/DutyFreeShopsLOGO.png" Width="500" Height="Auto" HorizontalAlignment="Center" Margin="0,0,0,60"/>
            <!--Buttons-->
                <StackPanel Background="Transparent" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button x:Name="ClientButton"
                        Style="{StaticResource ButtonStyle}"
                        Content="I'm a client"
                        Command="{Binding SelectClientCommand}"
                        Foreground="White"/>

                <Button x:Name="AdminButton"
                        Style="{StaticResource ButtonStyle}"
                        Content="I'm an admin"
                        Command="{Binding SelectAdminCommand}" 
                        Foreground="White"/>

                <TextBlock x:Name="ErrorText"
                           Foreground="Red"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
