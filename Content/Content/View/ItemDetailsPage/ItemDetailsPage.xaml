<Window
    x:Class="Content.ItemDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Content"
    mc:Ignorable="d"
    Title="Duty-free shops">

    <Grid x:Name="Root" Background="#F6F7F9">
        <Grid.Resources>
            <SolidColorBrush x:Key="AccentTeal" Color="#2BB8C0" />
            <SolidColorBrush x:Key="MutedText" Color="#6B7280" />
            <SolidColorBrush x:Key="CardBorder" Color="#E7EDF3" />
            <SolidColorBrush x:Key="Divider" Color="#E5E7EB" />
            <SolidColorBrush x:Key="DarkText" Color="#111827" />

            <SolidColorBrush x:Key="DisabledBg" Color="#F3F4F6" />
            <SolidColorBrush x:Key="DisabledBorder" Color="#E5E7EB" />
            <SolidColorBrush x:Key="DisabledText" Color="#9CA3AF" />

            <SolidColorBrush x:Key="TextBoxBg" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextBoxBorder" Color="#E5E7EB" />
            <SolidColorBrush x:Key="PlaceholderBrush" Color="#9CA3AF" />
            <SolidColorBrush x:Key="SelectionBrush" Color="#332BB8C0" />

            <SolidColorBrush x:Key="TextControlForeground" Color="#111827" />
            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#111827" />
            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#111827" />
            <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#9CA3AF" />

            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#9CA3AF" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#9CA3AF" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#9CA3AF" />
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled" Color="#9CA3AF" />

            <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#332BB8C0" />
            <SolidColorBrush x:Key="TextControlSelectionHighlightColorFocused" Color="#332BB8C0" />

            <SolidColorBrush x:Key="TextControlBackground" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#F3F4F6" />

            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#E5E7EB" />
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#E5E7EB" />
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#2BB8C0" />

            <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
            <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>

            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#F3F4F6" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E5E7EB" />
            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#CBD5E1" />
            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#94A3B8" />
            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#111827" />
            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#111827" />

            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#E5E7EB" />
            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#CBD5E1" />
            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#6B7280" />

            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#23A7AE" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#1E9096" />
            <SolidColorBrush x:Key="AccentButtonBorderBrushPointerOver" Color="#23A7AE" />
            <SolidColorBrush x:Key="AccentButtonBorderBrushPressed" Color="#1E9096" />
            <SolidColorBrush x:Key="AccentButtonForegroundPointerOver" Color="#FFFFFF" />
            <SolidColorBrush x:Key="AccentButtonForegroundPressed" Color="#FFFFFF" />

            <Style x:Key="ViewCartButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="44"/>
                <Setter Property="Padding" Value="16,0"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0"
              Height="78"
              Padding="32,0,32,0"
              VerticalAlignment="Top"
              Background="#F6F7F9">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackButton"
                    Grid.Column="0"
                    Height="44"
                    Padding="8,0"
                    CornerRadius="12"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    Click="BackButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE72B;"
                              FontFamily="Segoe Fluent Icons"
                              Foreground="{StaticResource DarkText}"
                              FontSize="18"/>
                    <TextBlock Text="Back"
                               Foreground="{StaticResource DarkText}"
                               VerticalAlignment="Center"
                               FontSize="14"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="1"
                       Text="Duty-free shops"
                       Margin="14,0,22,0"
                       VerticalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentTeal}" />

            <Border Grid.Column="2"
                    Height="44"
                    VerticalAlignment="Center"
                    CornerRadius="14"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    HorizontalAlignment="Stretch"
                    MaxWidth="680"
                    MinWidth="260">
                <Grid Padding="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Glyph="&#xE721;" FontFamily="Segoe Fluent Icons" Foreground="#9CA3AF" />
                    <TextBlock Grid.Column="1"
                               Text="Search..."
                               Foreground="#9CA3AF"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Center"
                        Margin="18,0,0,0">

                <Button x:Name="ViewCartButton"
                        Style="{StaticResource ViewCartButtonStyle}"
                        Click="ViewCart_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="ViewCartIcon"
                                  Glyph="&#xE7BF;"
                                  FontFamily="Segoe Fluent Icons"
                                  Foreground="#111827" />
                        <TextBlock x:Name="ViewCartText"
                                   Text="View Cart"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="#F6F7F9"
                Padding="32,14,32,18">
            <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                <TextBlock Text="Sort by:"
                           Foreground="{StaticResource MutedText}"
                           VerticalAlignment="Center"/>

                <ComboBox Width="220"
                          SelectedIndex="0"
                          IsHitTestVisible="False"
                          IsTabStop="False"
                          Opacity="0.65"
                          Background="{StaticResource DisabledBg}"
                          BorderBrush="{StaticResource DisabledBorder}"
                          Foreground="{StaticResource DarkText}">
                    <ComboBoxItem Content="Alphabetic" />
                    <ComboBoxItem Content="Price (Low to High)" />
                    <ComboBoxItem Content="Price (High to Low)" />
                    <ComboBoxItem Content="Newest" />
                </ComboBox>

                <TextBlock Text="(Sorting disabled on detail page)"
                           Foreground="{StaticResource DisabledText}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid Padding="32,18,32,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border CornerRadius="18"
                        Background="White"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1"
                        Margin="0,0,26,0"
                        Height="560"
                        VerticalAlignment="Top">
                    <Image x:Name="ProductImage"
                           Source="{Binding Photo, Converter={StaticResource PathToImageConverter}}"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>

                <Border Grid.Column="1"
                        CornerRadius="18"
                        Background="White"
                        BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1">
                    <Grid Padding="28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TitleText"
                                   Text="Premium Gold Watch"
                                   FontSize="36"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource DarkText}"
                                   TextWrapping="WrapWholeWords"/>

                        <TextBlock x:Name="DescText"
                                   Grid.Row="1"
                                   Margin="0,14,0,0"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{StaticResource MutedText}"
                                   FontSize="16"
                                   LineHeight="24"
                                   Text="An exquisite timepiece crafted with precision and elegance. This premium gold watch features a sophisticated design with a durable stainless steel case, sapphire crystal glass, and a luxurious gold-tone finish. Perfect for any occasion, combining timeless style with modern functionality."/>

                        <TextBlock x:Name="PriceText"
                                   Grid.Row="2"
                                   Margin="0,26,0,0"
                                   Text="$2,499.00"
                                   FontSize="44"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentTeal}"/>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                            <Ellipse Width="10" Height="10" Fill="#16A34A" VerticalAlignment="Center"/>
                            <TextBlock Foreground="{StaticResource DarkText}">
								<Run Text="In Stock:"/>
								<Run Text=" "/>
								<Run x:Name="StockUnitsRun" Text="15 units" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>

                        <Rectangle Grid.Row="4"
                                   Height="1"
                                   Fill="{StaticResource Divider}"
                                   Margin="0,22,0,22"/>

                        <!-- CLIENT -->
                        <StackPanel x:Name="ClientActionsPanel"
                                    Grid.Row="5"
                                    Spacing="18"
                                    Visibility="Visible">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Quantity:"
                                           Foreground="{StaticResource MutedText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,14,0"/>

                                <Border Grid.Column="1"
                                        CornerRadius="14"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Background="White"
                                        Padding="6"
                                        HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Width="44" Height="44"
                                                CornerRadius="10"
                                                Background="#F3F4F6"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                Click="QuantityMinus_Click">
                                            <FontIcon Glyph="&#xE108;"
                                                      FontFamily="Segoe Fluent Icons"
                                                      Foreground="{StaticResource DarkText}" />
                                        </Button>

                                        <TextBox x:Name="QuantityBox"
                                                 Grid.Column="1"
                                                 Width="72"
                                                 Height="44"
                                                 Margin="10,0"
                                                 Text="1"
                                                 FontSize="16"
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource DarkText}"
                                                 Background="{StaticResource TextBoxBg}"
                                                 BorderBrush="{StaticResource TextBoxBorder}"
                                                 BorderThickness="1"
                                                 SelectionHighlightColor="{StaticResource SelectionBrush}"
                                                 PlaceholderForeground="{StaticResource PlaceholderBrush}"
                                                 HorizontalTextAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 CornerRadius="10" />

                                        <Button Grid.Column="2"
                                                Width="44" Height="44"
                                                CornerRadius="10"
                                                Background="#F3F4F6"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                Click="QuantityPlus_Click">
                                            <FontIcon Glyph="&#xE109;"
                                                      FontFamily="Segoe Fluent Icons"
                                                      Foreground="{StaticResource DarkText}" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Button Content="Add to Cart"
                                    Height="64"
                                    CornerRadius="12"
                                    Background="{StaticResource AccentTeal}"
                                    Foreground="White"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Click="AddToCart_Click"/>
                        </StackPanel>

                        <!-- ADMIN -->
                        <StackPanel x:Name="AdminActionsPanel"
                                    Grid.Row="5"
                                    Spacing="14"
                                    Visibility="Collapsed">

                            <TextBlock Text="Admin: Edit product info"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource DarkText}" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="Name" Foreground="{StaticResource MutedText}" />
                                <TextBox x:Name="AdminNameBox"
                                         PlaceholderText="Product name"
                                         Foreground="{StaticResource DarkText}"
                                         Background="{StaticResource TextBoxBg}"
                                         BorderBrush="{StaticResource TextBoxBorder}"
                                         BorderThickness="1"
                                         SelectionHighlightColor="{StaticResource SelectionBrush}"
                                         PlaceholderForeground="{StaticResource PlaceholderBrush}"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Description" Foreground="{StaticResource MutedText}" />
                                <TextBox x:Name="AdminDescBox"
                                         PlaceholderText="Product description"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="110"
                                         Foreground="{StaticResource DarkText}"
                                         Background="{StaticResource TextBoxBg}"
                                         BorderBrush="{StaticResource TextBoxBorder}"
                                         BorderThickness="1"
                                         SelectionHighlightColor="{StaticResource SelectionBrush}"
                                         PlaceholderForeground="{StaticResource PlaceholderBrush}"/>
                            </StackPanel>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock Text="Price" Foreground="{StaticResource MutedText}" />
                                    <TextBox x:Name="AdminPriceBox"
                                             PlaceholderText="Price (e.g. 2499.00)"
                                             Foreground="{StaticResource DarkText}"
                                             Background="{StaticResource TextBoxBg}"
                                             BorderBrush="{StaticResource TextBoxBorder}"
                                             BorderThickness="1"
                                             SelectionHighlightColor="{StaticResource SelectionBrush}"
                                             PlaceholderForeground="{StaticResource PlaceholderBrush}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Stock" Foreground="{StaticResource MutedText}" />
                                    <TextBox x:Name="AdminStockBox"
                                             PlaceholderText="Stock (e.g. 15)"
                                             Foreground="{StaticResource DarkText}"
                                             Background="{StaticResource TextBoxBg}"
                                             BorderBrush="{StaticResource TextBoxBorder}"
                                             BorderThickness="1"
                                             SelectionHighlightColor="{StaticResource SelectionBrush}"
                                             PlaceholderForeground="{StaticResource PlaceholderBrush}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,6,0,0">
                                <Button Content="Save Changes"
                                        Height="44"
                                        CornerRadius="12"
                                        Background="{StaticResource AccentTeal}"
                                        Foreground="White"
                                        FontWeight="SemiBold"
                                        Click="AdminSave_Click"/>
                            </StackPanel>

                            <TextBlock x:Name="AdminStatusText"
                                       Text=""
                                       Foreground="{StaticResource MutedText}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>