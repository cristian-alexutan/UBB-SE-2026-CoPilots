<Window
    x:Class="Content.ShopPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Content">

    <Grid Background="#F9FAFB" Padding="100 0 0 0" RequestedTheme="Light">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Padding="20 30 30 30" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Text="DutyFree Shops"
                FontSize="32"
                FontWeight="SemiBold"
                Foreground="#2bb8c0" />

            <AutoSuggestBox
                Grid.Column="1"
                Height="40"
                PlaceholderText="Search shops or categories..."
                CornerRadius="8"
                Width="500"
                Margin="0 5 0 0"
                BorderBrush="LightGray" />

            <Button Grid.Column="2"
                    CornerRadius="4"
                    Padding="15,8"
                    BorderThickness="0">
                <SymbolIcon Symbol="Contact" Foreground="Gray" />
            </Button>

            <Button Grid.Column="3"
                    Background="#2bb8c0"
                    Foreground="White"
                    CornerRadius="4"
                    Padding="15,8">
                <SymbolIcon Symbol="Shop" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,30,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" /> <!-- added this for space -->
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                Margin="20 0 0 0 "
                Grid.Column="0"
                x:Name="AddShopButton"
                Height="35" Width="110"
                Background="#2bb8c0" Foreground="White"
                Padding="5"
                Content="+ Add Shop" />


            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10"
                        VerticalAlignment="Center">
                <TextBlock Text="Sort by:" VerticalAlignment="Center" Opacity="0.7" />
                <ComboBox Width="220" SelectedIndex="0" Padding="5,2">
                    <ComboBoxItem Content="Shop Name" />
                    <ComboBoxItem Content="Reviews" />
                </ComboBox>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2">
            <GridView x:Name="ShopsGridView" Padding="20">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"
                                       MaximumRowsOrColumns="5"
                                       />
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>

                

                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:ShopItem">
                        <Border MinWidth="300"
                                Height="120"
                                Margin="10"
                                CornerRadius="12"
                                Background="WhiteSmoke"
                                Padding="15">

                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{x:Bind Name}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="Black"
                                               Grid.Column="0"
                                               VerticalAlignment="Center" />

                                    <Button Width="40" Height="30" Grid.Column="1" Click="EditShopButton_Click"
                                            DataContext="{Binding}"
                                            Margin="0 0 10 0"
                                            Visibility="{x:Bind AdminVisibility, Mode=OneWay}">
                                        <TextBlock Text="✎" FontSize="14" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>

                                    <Button Width="40" Height="30" Grid.Column="2" Click="DeleteShopButton_Click"
                                            DataContext="{Binding}"
                                            Visibility="{x:Bind AdminVisibility, Mode=OneWay}">
                                        <TextBlock Text="-"  FontSize="20" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Button>
                                </Grid>

                                <TextBlock Text="{x:Bind Category}"
                                           Margin="0,5,0,0"
                                           Opacity="0.6"
                                           Foreground="Black" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>

            </GridView>
        </ScrollViewer>

    </Grid>
</Window>