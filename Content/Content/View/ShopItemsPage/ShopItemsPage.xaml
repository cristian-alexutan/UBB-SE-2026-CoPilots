<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Content.ShopItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Content"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="alwaysGonnaGiveYouUp">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    
    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" Padding="0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                    <Grid>
                        <SymbolIcon Width="10" Height="10" Foreground="#2bb8c0" HorizontalAlignment="Left" Symbol="Back"/>
                        <TextBlock Margin="20,0,0,0" VerticalAlignment="Center" Foreground=" #2bb8c0" Text="Back to Shops" />
                    </Grid>
                    
                    <Border Width="1" Grid.Column="1" Background="LightGray" Margin="5,0" Height="30"/>
                    <TextBlock VerticalAlignment="Center" FontSize="24px" Foreground=" #2bb8c0" Text="Duty-free items" />

                    <Grid Padding="50,0,0,0" Width="500" Height="50">
                        <TextBox FontSize="18px" x:Name="SearchBox"
                         PlaceholderText="Search"
                         Padding="35,13,0,0" 
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"/>

                        <SymbolIcon Symbol="Find"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="10,0,0,0"
                        Foreground="Gray"/> 
                    </Grid>

                    <SymbolIcon Symbol="Contact" Margin="50,20,0,20"></SymbolIcon>
                    
                    <Button Width="100" Height="45" CornerRadius="13" Background="Gray" Margin="20,0,0,0">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Gray"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Gray"/>
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Gray"/>
                        </Button.Resources>
                        <Grid>
                            <FontIcon HorizontalAlignment="Left"  FontFamily="Segoe MDL2 Assets" Glyph="&#xE7BF;" Foreground="White"/>
                            <TextBlock Foreground="White" FontSize="18px" Margin="30,0,0,0" Text="Cart"></TextBlock>
                        </Grid>
                    </Button>

                </StackPanel>

                <Border Height="2" Background="LightGray" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="150,25">
            <StackPanel Spacing="20">
                <Button  Click="AddButton_Click" FontSize="16" Foreground="White" Content="+ Add Item" CornerRadius="15" Background="#2bb8c0" Width="130" Height="50"/>

                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Sort by:"  VerticalAlignment="Center"></TextBlock>
                    <Button  VerticalAlignment="Center" Grid.Column="1" FontSize="16" Foreground="White" Content="Alphabetic (Item Name)"
                             CornerRadius="10" Background="#2bb8c0" Height="40"/>
                    
                    <!-- !!! watch out cause button only blue when selected !!! -->
                    
                    <Button IsEnabled="False" VerticalAlignment="Center" FontSize="16" Foreground="White" Content="Numeric (Complaints)"
         CornerRadius="10" Background="#2bb8c0" Height="40" Grid.Column="2"/>
                    <Button VerticalAlignment="Center" FontSize="16" Foreground="Black" Content="Numeric (Price)"
CornerRadius="10" Background="LightGray" Height="40" Grid.Column="3"/>
                </Grid>

                <GridView>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="8" Padding="10" Margin="5">
                                <StackPanel Width="250" Height="300">
                                    <!-- Image with overlay buttons -->
                                    <Grid Height="180" Width="200">
                                        <Image Source="placeholder.png" Stretch="UniformToFill" />

                                        <!-- Overlay buttons -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5" Spacing="5">
                                            <Button Click="EditButton_Click" Width="24" Height="24" Padding="0" Background="#80FFFFFF" BorderBrush="Transparent">
                                                <Viewbox Stretch="Uniform">
                                                    <SymbolIcon Symbol="Edit"/>
                                                </Viewbox>
                                            </Button>
                                            <Button Width="24" Height="24" Padding="0" Background="#80FFFFFF" BorderBrush="Transparent">
                                                <Viewbox Stretch="Uniform">
                                                    <SymbolIcon Foreground="DarkRed" Symbol="Delete"/>
                                                </Viewbox>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Text below image -->
                                    <TextBlock Text="Sample Title" FontWeight="Bold" Margin="0,20,0,0"/>
                                    <TextBlock Text="Sample description" TextWrapping="Wrap" Margin="0,10,0,5"/>
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Text="Stock: 24" TextWrapping="Wrap" Margin="0,20,0,5"/>
                                        <TextBlock FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="24" Foreground="#2bb8c0" Text="$120.99"></TextBlock>
                                    </Grid>
                                    
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>

                    <!-- 8 hardcoded items -->
                    <GridView.Items>
                        <x:String>1</x:String>
                        <x:String>2</x:String>
                        <x:String>3</x:String>
                        <x:String>4</x:String>
                        <x:String>5</x:String>
                        <x:String>6</x:String>
                        <x:String>7</x:String>
                        <x:String>8</x:String>
                    </GridView.Items>
                </GridView>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
